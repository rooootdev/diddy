[ ca ]
default_ca = demo_ca

[ demo_ca ]
dir = ./democa
certs = $dir
new_certs_dir = $dir/newcerts
database = $dir/index.txt
serial = $dir/serial
private_key = key.pem
certificate = cert.pem
default_days = 3650
default_md = sha256
policy = policy_any

[ policy_any ]
countryName = optional
stateOrProvinceName = optional
organizationName = optional
commonName = supplied